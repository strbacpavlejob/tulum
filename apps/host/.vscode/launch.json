{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "pwa-chrome",
      "request": "launch",
      "name": "Launch Brave against localhost",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "runtimeExecutable": "/snap/bin/brave",
      "runtimeArgs": ["--remote-debugging-port=9222"]
    }
  ]
}
